# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and aqcuire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local
CI=false
PROXY_HTTP_PORT=8008
PROXY_DASHBOARD_PORT=8091
ADMINER_HOST_PORT=8081
BACKEND_HOST_PORT=18000
FRONTEND_DEV_PORT=5174
MAILCATCHER_HTTP_PORT=1081
MAILCATCHER_SMTP_HOST_PORT=1026
PLAYWRIGHT_REPORT_PORT=9323
RABBITMQ_HOST_PORT=5673
RABBITMQ_MANAGEMENT_HOST_PORT=15673
OSRM_HOST_PORT=5000

PROJECT_NAME=aegis-o2o
STACK_NAME=aegis-o2o

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174,https://localhost,https://localhost:5173,https://localhost:5174,http://localhost.tiangolo.com"

# =========================================================================
# 🔒 BẢO MẬT: THAY THẾ CÁC GIÁ TRỊ DƯỚI ĐÂY BẰNG MÃ NGẪU NHIÊN KHI DEPLOY
# Có thể chạy lệnh này để sinh mã an toàn: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =========================================================================
SECRET_KEY=<generate-a-secure-random-string-here>
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=<generate-a-secure-random-string-here>

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5434
POSTGRES_DB=aegis_db

# =========================================================================
# 🔒 DATABASE CREDENTIALS: THAY THẾ MẬT KHẨU KHI DEPLOY PRODUCTION
# =========================================================================
POSTGRES_USER=aegis_user
POSTGRES_PASSWORD=<generate-a-secure-random-string-here>

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# =========================================================================
# 🏗️ INFRASTRUCTURE SERVICES (P0-01 / P0-10)
# =========================================================================
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
OPTIMIZATION_SERVICE_URL=http://optimization_service:8001/api/v1/optimize

# OSRM Private Routing Server (docker --profile routing)
# Mặc định dùng container nội bộ, fallback public server nếu chưa setup
OSRM_BASE_URL=http://osrm-backend:5000

# Internal secret for service-to-service auth (Celery → API)
# Sinh mã: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SECRET_KEY=<generate-a-secure-random-string-here>

# Gemini AI (Vision & Heritage modules)
GEMINI_API_KEY=
